PORT=8080
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# OpenAI-compatible open-source model endpoint.
# Ollama example: http://localhost:11434/v1
# vLLM example: http://localhost:8000/v1
AI_BASE_URL=http://localhost:11434/v1
AI_MODEL=deepseek-r1:8b
AI_API_KEY=ollama
AI_TIMEOUT_MS=90000

# Optional deployment-facing label
AI_PROVIDER_LABEL=ollama

# Optional web search via your own SearXNG instance
SEARCH_BASE_URL=
SEARCH_TIMEOUT_MS=12000
