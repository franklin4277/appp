PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/forex_journal
# Comma-separated list supported. Example:
# CLIENT_URL=http://localhost:5173,https://appp-1-a52k.onrender.com
# You can also use wildcard patterns like: *.onrender.com
CLIENT_URL=http://localhost:5173
# Keep false unless you want to strictly block unknown origins.
STRICT_CORS=false
JWT_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_EXPIRES_IN=20m
JWT_REFRESH_EXPIRES_IN=30d
API_RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_MAX=30
REGISTER_RATE_LIMIT_MAX=12
RECOVERY_RATE_LIMIT_MAX=20

# Optional cloud image storage (falls back to local /uploads if missing)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=trading-journal

# Security and recovery
PASSWORD_RESET_EXPIRES_IN=30m
EMAIL_VERIFY_EXPIRES_IN=48h
TWO_FACTOR_EXPIRES_IN=10m
# Enable for local/manual testing only. Keep false in production.
ALLOW_DEBUG_AUTH_SECRETS=false

# Monitoring and alerting
# Optional token for /api/metrics; if empty, endpoint is open.
METRICS_TOKEN=
# Optional webhook URL for alert delivery (Slack/Discord/custom endpoint)
ALERT_WEBHOOK_URL=
ERROR_ALERT_THRESHOLD=12
FAILED_LOGIN_ALERT_THRESHOLD=20

# Optional public URL used for shared weekly reports
PUBLIC_SHARE_BASE_URL=http://localhost:5173

# Auto backup settings
DISABLE_AUTO_BACKUP=false
BACKUP_INTERVAL_MINUTES=60
BACKUP_DIR=
