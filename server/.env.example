PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/forex_journal
# Comma-separated list supported. Example:
# CLIENT_URL=http://localhost:5173,https://appp-1-a52k.onrender.com
# You can also use wildcard patterns like: *.onrender.com
CLIENT_URL=http://localhost:5173
# Keep false unless you want to strictly block unknown origins.
STRICT_CORS=false
JWT_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_EXPIRES_IN=20m
JWT_REFRESH_EXPIRES_IN=30d
API_RATE_LIMIT_MAX=500
JSON_BODY_LIMIT=12mb
AUTH_RATE_LIMIT_MAX=30
REGISTER_RATE_LIMIT_MAX=12
RECOVERY_RATE_LIMIT_MAX=20

# MT5 bridge security + reconciliation
MT5_BRIDGE_REQUIRE_HMAC=false
MT5_BRIDGE_TIMESTAMP_TOLERANCE_SECONDS=300
MT5_BRIDGE_IP_ALLOWLIST=
BRIDGE_EVENT_RETENTION_DAYS=45
BRIDGE_RATE_LIMIT_PER_MINUTE=240
BRIDGE_RECONCILE_INTERVAL_SECONDS=180
BRIDGE_RECONCILE_BATCH_SIZE=120
BRIDGE_STALE_OPEN_TRADE_MINUTES=25
BRIDGE_ENABLE_RECORDINGS=false
BRIDGE_MAX_RECORDING_SECONDS=20
RECORDING_RETENTION_DAYS=14
RECORDING_RETENTION_INTERVAL_HOURS=6

# Optional cloud image storage (falls back to local /uploads if missing)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=trading-journal

# Security and recovery
PASSWORD_RESET_EXPIRES_IN=30m
EMAIL_VERIFY_EXPIRES_IN=48h
TWO_FACTOR_EXPIRES_IN=10m
# Enable for local/manual testing only. Keep false in production.
ALLOW_DEBUG_AUTH_SECRETS=false

# Monitoring and alerting
# Optional token for /api/metrics; if empty, endpoint is open.
METRICS_TOKEN=
# Optional webhook URL for alert delivery (Slack/Discord/custom endpoint)
ALERT_WEBHOOK_URL=
ERROR_ALERT_THRESHOLD=12
FAILED_LOGIN_ALERT_THRESHOLD=20

# Optional public URL used for shared weekly reports
PUBLIC_SHARE_BASE_URL=http://localhost:5173

# Billing / monetization scaffold
BILLING_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_CHECKOUT_BASE_URL=https://checkout.stripe.com/pay
STRIPE_PORTAL_BASE_URL=https://billing.stripe.com/p/login

# SMTP email delivery (required for production 2FA email codes)
# Alternative single connection string:
# SMTP_URL=smtps://user:pass@smtp.example.com:465
SMTP_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_REQUIRE_TLS=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_TLS_SERVERNAME=
EMAIL_FROM="The Trading Journal <no-reply@example.com>"

# Auto backup settings
DISABLE_AUTO_BACKUP=false
BACKUP_INTERVAL_MINUTES=60
BACKUP_DIR=
